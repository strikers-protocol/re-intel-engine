# Groq API Key — FREE — get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Secret key for JWT tokens
SECRET_KEY=strikers_protocol_change_this_secret_2024

# App settings
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# File upload limit (MB)
MAX_UPLOAD_SIZE_MB=50

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/strikers.db

# Paths
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
